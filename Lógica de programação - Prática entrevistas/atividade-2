# Solicita o tipo de conversão
tipo_conversao = input(
    "Digite C para Celsius -> Fahrenheit ou F para Fahrenheit -> Celsius: "
).upper()

# Conversão de Celsius para Fahrenheit
if tipo_conversao == "C":
    temperatura_celsius = float(input("Digite a temperatura em Celsius: "))
    
    temperatura_fahrenheit = (temperatura_celsius * 9 / 5) + 32
    
    print("Temperatura em Fahrenheit:", temperatura_fahrenheit)

# Conversão de Fahrenheit para Celsius
elif tipo_conversao == "F":
    temperatura_fahrenheit = float(input("Digite a temperatura em Fahrenheit: "))
    
    temperatura_celsius = (temperatura_fahrenheit - 32) * 5 / 9
    
    print("Temperatura em Celsius:", temperatura_celsius)

# Opção inválida
else:
    print("Opção de conversão inválida.")
