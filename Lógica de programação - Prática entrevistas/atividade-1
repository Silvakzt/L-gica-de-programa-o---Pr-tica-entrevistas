# Solicita ao usuário um número inteiro
numero = int(input("Digite um número inteiro: "))

# Verifica se o resto da divisão por 2 é igual a zero
if numero % 2 == 0:
    print("O número é par.")
else:
    print("O número é ímpar.")

# Percorre os números de 1 até 100
for numero_atual in range(1, 101):

    # Verifica o número é múltiplo de 3 e 5 ao mesmo tempo
    if numero_atual % 3 == 0 and numero_atual % 5 == 0:
        print("FizzBuzz")

    # Verifica se o número é múltiplo apenas de 3
    elif numero_atual % 3 == 0:
        print("Fizz")

    # Verifica se o número é múltiplo apenas de 5
    elif numero_atual % 5 == 0:
        print("Buzz")

    # Caso não seja múltiplo de 3 nem de 5 exibe o próprio número
    else:
        print(numero_atual)

# Solicita um número inteiro positivo
numero = int(input("Digite um número inteiro positivo: "))

# guarda o fatorial
resultado_fatorial = 1

# Multiplica todos os números de 1 até o valor informado
for multiplicador in range(1, numero + 1):
    resultado_fatorial *= multiplicador

# Exibe resultado final
print(f"O fatorial de {numero} é {resultado_fatorial}.")